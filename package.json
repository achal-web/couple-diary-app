{
  "name": "couple-diary-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pod-install": "cd ios && pod install && cd ..",
    "clean-android": "cd android && ./gradlew clean && cd ..",
    "clean-ios": "cd ios && rm -rf Pods Podfile.lock && pod install && cd ..",
    "clean-all": "npm run clean-android && npm run clean-ios && npm start -- --reset-cache"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/stack": "^6.3.0",
    "react-native-screens": "^3.22.0",
    "react-native-safe-area-context": "^4.5.0",
    "react-native-gesture-handler": "^2.12.0",
    "firebase": "^9.23.0",
    "redux": "^4.2.0",
    "react-redux": "^8.1.0",
    "@reduxjs/toolkit": "^1.9.0",
    "axios": "^1.5.0",
    "react-native-vector-icons": "^9.2.0",
    "react-native-image-picker": "^5.5.0",
    "react-native-permissions": "^3.8.0",
    "react-native-dotenv": "^3.3.1",
    "uuid": "^9.0.0",
    "@react-native-async-storage/async-storage": "^1.18.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "babel-jest": "^29.7.0",
    "@react-native/metro-config": "^0.72.0",
    "@testing-library/react-native": "^12.1.0",
    "jest": "^29.7.0",
    "eslint": "^8.49.0",
    "eslint-plugin-react-native": "^4.1.0",
    "prettier": "^3.0.0",
    "typescript": "^5.1.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
}
